# ══════════════════════════════════════════════════════════════════
#  API KEYS — City Scrapper
#  Copy this file to ../.env and fill in your keys.
#  Never commit the actual .env file to GitHub.
# ══════════════════════════════════════════════════════════════════


# ── CORE AI (required) ────────────────────────────────────────────
# Claude AI — powers all reasoning, extraction, and validation
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=


# ── PROPERTY DATA (add one or more) ──────────────────────────────
# Regrid — nationwide parcel + ownership data (all 50 states)
# Get key: https://regrid.com/api
REGRID_API_KEY=

# BatchData — property + skip tracing in one call (all 50 states)
# Get key: https://batchdata.com
BATCHDATA_API_KEY=

# Reonomy — commercial real estate owner identity + contacts
# Get key: https://www.reonomy.com
REONOMY_API_KEY=


# ── CONTACT ENRICHMENT (add one or more) ─────────────────────────
# Apollo.io — email + phone + LinkedIn for people (PRIMARY)
# Get key: https://app.apollo.io/#/settings/integrations/api
APOLLO_API_KEY=

# People Data Labs (PDL) — best pay-as-you-go contact enrichment
# Get key: https://www.peopledatalabs.com/signup
PDL_API_KEY=

# Lusha — direct dials + emails
# Get key: https://www.lusha.com
LUSHA_API_KEY=

# Hunter.io — email finder by domain (fallback)
# Get key: https://hunter.io/api-keys
HUNTER_API_KEY=

# Proxycurl — LinkedIn profile data
# Get key: https://nubela.co/proxycurl
PROXYCURL_API_KEY=

# Apify — LinkedIn scraper actor
# Get key: https://console.apify.com/account/integrations
APIFY_API_KEY=


# ── WEB SEARCH (add one or more for best results) ─────────────────
# Exa.ai — semantic web search (recommended)
# Get key: https://exa.ai
EXA_API_KEY=

# Google Custom Search — fallback web search
# Get key: https://developers.google.com/custom-search/v1/introduction
GOOGLE_CSE_API_KEY=
GOOGLE_CSE_ID=


# ── EMAIL VALIDATION ──────────────────────────────────────────────
# NeverBounce — verify emails are real and deliverable (~$0.003/check)
# Get key: https://app.neverbounce.com/settings/api
NEVERBOUNCE_API_KEY=

# ZeroBounce — alternative email validator
# Get key: https://www.zerobounce.net/members/apikey/
ZEROBOUNCE_API_KEY=


# ── ADDRESS VALIDATION (optional) ────────────────────────────────
# Smarty — US street address standardization
# Get key: https://www.smarty.com/pricing
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=


# ── OUTPUTS ───────────────────────────────────────────────────────
# Google Sheets — auto-export results to a sheet
# Paste the Sheet ID from your Google Sheet URL
GOOGLE_SHEET_ID=


# ── PIPELINE BEHAVIOUR ────────────────────────────────────────────
# Roles that should have phone enrichment attempted
ENRICH_PHONE_ROLES=Developer,GC
