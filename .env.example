# ─────────────────────────────────────────────
# Model 2 — Leadership Pipeline (required)
# ─────────────────────────────────────────────

# Exa.ai — neural web search
# Get key at: exa.ai
EXA_API_KEY=

# Anthropic — Claude Haiku LLM
# Get key at: console.anthropic.com
ANTHROPIC_API_KEY=

# Hunter.io — email discovery
# Get key at: hunter.io (free: 50 searches/mo)
HUNTER_API_KEY=

# Apify — LinkedIn profile scraping (optional)
# Get key at: apify.com
APIFY_API_KEY=


# ─────────────────────────────────────────────
# Model 1 — Full Stakeholder Pipeline (required)
# ─────────────────────────────────────────────

# Smarty Streets — address normalization
# Get key at: smarty.com (free: 250/mo)
SMARTY_AUTH_ID=
SMARTY_AUTH_TOKEN=

# Shovels.ai — permit + contractor data
# Get key at: shovels.ai (paid: $599/mo)
SHOVELS_API_KEY=

# ATTOM Data — property ownership + lender records
# Get key at: api.attomdata.com (paid: ~$95/mo)
ATTOM_API_KEY=

# OpenCorporates — LLC officer resolution
# Get key at: opencorporates.com/info/api (free: 200/mo)
OPENCORPORATES_API_KEY=

# Apollo.io — email + phone + LinkedIn enrichment
# Get key at: apollo.io (free: 100 credits/mo)
APOLLO_API_KEY=

# Google Sheets — output destination
# See docs/MODEL1_STAKEHOLDER_PIPELINE.md for setup instructions
GOOGLE_SHEET_ID=

# Pipeline config
ENRICH_PHONE_ROLES=Developer,GC
